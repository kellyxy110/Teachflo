{
  "name": "teachflow-os",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @teachflow/database db:generate",
    "db:push": "pnpm --filter @teachflow/database db:push",
    "db:migrate": "pnpm --filter @teachflow/database db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
