// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// SCHOOL (TENANT)
// ─────────────────────────────────────────────

model School {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  state     String
  lga       String?
  address   String?
  logoUrl   String?
  plan      Plan     @default(FREE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teachers Teacher[]
  classes  Class[]
  students Student[]
  lessons  Lesson[]
  exams    Exam[]
  library   LibraryItem[]
  scores    Score[]
  documents Document[]

  @@map("schools")
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// ─────────────────────────────────────────────
// TEACHER
// ─────────────────────────────────────────────

model Teacher {
  id           String      @id @default(cuid())
  clerkId      String      @unique
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id])
  firstName    String
  lastName     String
  email        String
  role         TeacherRole @default(TEACHER)
  subjects     String[]
  isActive     Boolean     @default(true)
  photoUrl     String?
  bio          String?
  qualification String?
  department   String?
  yearsOfExp   Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  lessons  Lesson[]
  exams    Exam[]
  scores   Score[]
  homework Homework[]

  @@unique([schoolId, email])
  @@map("teachers")
}

enum TeacherRole {
  TEACHER
  HOD
  ADMIN
  SUPER_ADMIN
}

// ─────────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────────

model Class {
  id        String     @id @default(cuid())
  schoolId  String
  school    School     @relation(fields: [schoolId], references: [id])
  name      String
  level     ClassLevel
  arm       String?
  term      Term       @default(FIRST)
  session   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  students Student[]
  scores   Score[]
  lessons  Lesson[]
  exams    Exam[]
  homework Homework[]

  @@unique([schoolId, name, session])
  @@map("classes")
}

enum ClassLevel {
  JS1
  JS2
  JS3
  SS1
  SS2
  SS3
}

enum Term {
  FIRST
  SECOND
  THIRD
}

// ─────────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────────

model Student {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  firstName String
  lastName  String
  regNumber String?
  gender    Gender?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scores          Score[]
  examAttempts    ExamAttempt[]
  mistakePatterns MistakePattern[]
  learningPaths   LearningPath[]

  @@unique([schoolId, regNumber])
  @@map("students")
}

enum Gender {
  MALE
  FEMALE
}

// ─────────────────────────────────────────────
// SCORE
// ─────────────────────────────────────────────

model Score {
  id        String  @id @default(cuid())
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subject   String
  term      Term
  session   String

  ca1    Float?
  ca2    Float?
  exam   Float?
  total  Float?
  grade  String?
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subject, term, session])
  @@map("scores")
}

// ─────────────────────────────────────────────
// LESSON
// ─────────────────────────────────────────────

model Lesson {
  id        String     @id @default(cuid())
  schoolId  String
  school    School     @relation(fields: [schoolId], references: [id])
  teacherId String
  teacher   Teacher    @relation(fields: [teacherId], references: [id])
  classId   String?
  class     Class?     @relation(fields: [classId], references: [id])

  subject      String
  topic        String
  classLevel   ClassLevel
  week         Int?
  term         Term?

  objectives   String[]
  introduction String
  content      Json
  activities   Json[]
  evaluation   String[]
  homework     String[]

  mode         LessonMode @default(STANDARD)
  aiModel      String?
  promptTokens Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lessons")
}

enum LessonMode {
  STANDARD
  ELI12
  WAEC
  JAMB
  JUPEB
}

// ─────────────────────────────────────────────
// EXAM
// ─────────────────────────────────────────────

model Exam {
  id        String     @id @default(cuid())
  schoolId  String
  school    School     @relation(fields: [schoolId], references: [id])
  teacherId String
  teacher   Teacher    @relation(fields: [teacherId], references: [id])
  classId   String?
  class     Class?     @relation(fields: [classId], references: [id])

  title      String
  subject    String
  topic      String
  classLevel ClassLevel
  examType   ExamType
  difficulty Difficulty
  duration   Int?

  examMode       ExamMode @default(STANDARD)
  blueprint      Json?
  totalQuestions  Int?
  targetStudentId String?

  questions Question[]
  attempts  ExamAttempt[]

  aiModel      String?
  promptTokens Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exams")
}

enum ExamType {
  SCHOOL_TEST
  SCHOOL_EXAM
  WAEC_MOCK
  JAMB_PREP
  JUPEB_PREP
}

enum Difficulty {
  BASIC
  APPLICATION
  WAEC
  JAMB
  JUPEB
}

enum ExamMode {
  STANDARD
  DIAGNOSTIC
  PRACTICE
  ASSESSMENT
  ADAPTIVE
}

// ─────────────────────────────────────────────
// QUESTION
// ─────────────────────────────────────────────

model Question {
  id     String @id @default(cuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  section      Section
  number       Int
  type         QuestionType

  stem          String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  optionE       String?
  correctOption String?

  questionText String?
  markScheme   String?

  solution       String
  explanation    String
  distractors    Json?
  commonMistakes String?
  examTip        String?
  curriculumRef  String?

  difficulty      String?  @default("medium")
  bloomLevel      String?
  skillTag        String?
  topicTag        String?
  subTopicTag     String?
  questionSource  String?  @default("synthetic")
  estimatedTime   Int?     @default(90)
  relatedChunkIds String[]

  createdAt DateTime @default(now())

  responses QuestionResponse[]
  tags      QuestionTag[]

  @@map("questions")
}

enum Section {
  A
  B
  C
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  ESSAY
  STRUCTURED
  CALCULATION
}

// ─────────────────────────────────────────────
// HOMEWORK
// ─────────────────────────────────────────────

model Homework {
  id          String         @id @default(cuid())
  schoolId    String
  teacherId   String
  teacher     Teacher        @relation(fields: [teacherId], references: [id])
  classId     String
  class       Class          @relation(fields: [classId], references: [id])

  subject     String
  title       String
  description String
  dueDate     DateTime?
  status      HomeworkStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("homework")
}

enum HomeworkStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

// ─────────────────────────────────────────────
// LIBRARY
// ─────────────────────────────────────────────

model LibraryItem {
  id       String  @id @default(cuid())
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  title        String
  subject      String
  classLevel   ClassLevel?
  topic        String?
  category     LibraryCategory
  examType     ExamType?

  fileUrl  String
  fileSize Int?
  pageCount Int?

  isPublic      Boolean @default(false)
  isAIGenerated Boolean @default(false)

  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("library_items")
}

enum LibraryCategory {
  TEXTBOOK
  REVISION_GUIDE
  PAST_QUESTIONS
  FORMULA_SHEET
  TEACHER_NOTES
  AI_NOTES
}

// ─────────────────────────────────────────────
// EXAM ATTEMPT (student takes an exam)
// ─────────────────────────────────────────────

model ExamAttempt {
  id        String        @id @default(cuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id])
  examId    String
  exam      Exam          @relation(fields: [examId], references: [id])
  schoolId  String

  status     AttemptStatus @default(IN_PROGRESS)
  totalScore Float?
  maxScore   Float?
  percentage Float?
  grade      String?

  examMode           ExamMode @default(STANDARD)
  analytics          Json?
  currentDifficulty  String?  @default("medium")
  questionsAnswered  Int      @default(0)
  adaptiveState      Json?

  startedAt   DateTime @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?

  responses QuestionResponse[]

  @@unique([studentId, examId])
  @@index([schoolId])
  @@map("exam_attempts")
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// ─────────────────────────────────────────────
// QUESTION RESPONSE (student's answer per question)
// ─────────────────────────────────────────────

model QuestionResponse {
  id         String      @id @default(cuid())
  attemptId  String
  attempt    ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question     @relation(fields: [questionId], references: [id])

  selectedOption   String?
  textResponse     String?
  isCorrect        Boolean?
  score            Float?
  maxScore         Float    @default(1)
  timeSpentSeconds Int?

  misconception    String?
  feedback         String?
  errorType        String?
  difficultyAtTime String?

  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@map("question_responses")
}

// ─────────────────────────────────────────────
// QUESTION TAG (skill / topic metadata)
// ─────────────────────────────────────────────

model QuestionTag {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  skill       String
  topic       String?
  subtopic    String?
  bloomsLevel BloomsLevel?

  @@unique([questionId, skill])
  @@index([skill])
  @@map("question_tags")
}

enum BloomsLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

// ─────────────────────────────────────────────
// DOCUMENT (uploaded PDFs for RAG)
// ─────────────────────────────────────────────

model Document {
  id        String         @id @default(cuid())
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  teacherId String

  title     String
  subject   String
  classLevel ClassLevel?
  fileName  String
  mimeType  String         @default("application/pdf")
  fileSize  Int            @default(0)
  pageCount Int?

  status    DocumentStatus @default(PENDING)
  chunkCount Int           @default(0)
  error     String?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([schoolId])
  @@map("documents")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// ─────────────────────────────────────────────
// MISTAKE INTELLIGENCE (Phase 2B)
// ─────────────────────────────────────────────

model MistakePattern {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId        String
  skill           String
  errorType       String
  pattern         String
  rootCause       String?
  prerequisiteGap String?
  occurrences     Int      @default(1)
  lastSeen        DateTime @default(now())
  firstSeen       DateTime @default(now())
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([studentId, skill, errorType])
  @@index([studentId])
  @@index([schoolId])
  @@index([skill])
  @@map("mistake_patterns")
}

// ─────────────────────────────────────────────
// ADAPTIVE LEARNING PATHS (Phase 2A)
// ─────────────────────────────────────────────

model LearningPath {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId       String
  subject        String
  classLevel     String
  steps          Json     @default("[]")
  currentStep    Int      @default(0)
  status         String   @default("ACTIVE")
  lastComputedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, subject])
  @@index([studentId])
  @@index([schoolId])
  @@map("learning_paths")
}

// ─────────────────────────────────────────────
// CURRICULUM PLANS (Phase 3A)
// ─────────────────────────────────────────────

model CurriculumPlan {
  id                 String   @id @default(cuid())
  schoolId           String
  teacherId          String
  subject            String
  classLevel         String
  term               String
  session            String
  title              String
  weeks              Json     @default("[]")
  assessmentSchedule Json?
  revisionCycles     Json?
  performanceContext Json?
  aiModel            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schoolId, subject, classLevel, term, session])
  @@index([schoolId])
  @@index([teacherId])
  @@map("curriculum_plans")
}

// ─────────────────────────────────────────────
// VECTOR TABLES (pgvector — managed via raw SQL)
// ─────────────────────────────────────────────

model LessonEmbedding {
  id        String                       @id @default(cuid())
  lessonId  String                       @unique
  schoolId  String
  content   String
  metadata  Json?
  embedding Unsupported("vector(1024)")
  createdAt DateTime                     @default(now())

  @@index([schoolId])
  @@map("lesson_embeddings")
}

model QuestionEmbedding {
  id         String                       @id @default(cuid())
  questionId String                       @unique
  schoolId   String
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime                     @default(now())

  @@index([schoolId])
  @@map("question_embeddings")
}

model DocumentChunk {
  id         String                       @id @default(cuid())
  documentId String
  schoolId   String
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1024)")
  chunkIndex Int                          @default(0)
  createdAt  DateTime                     @default(now())

  @@index([schoolId])
  @@index([documentId])
  @@map("document_chunks")
}
